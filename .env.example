# ============================================================================
# tarot-luxury — environment variables
# Copy to .env.local for local development. Production values live in Vercel.
# ============================================================================

# ── Groq AI (all 3 tools) ───────────────────────────────────────────────────
GROQ_API_KEY=

# ── Vercel Blob (admin overrides for content / prompts) ────────────────────
BLOB_READ_WRITE_TOKEN=

# ── Admin preview cookie shared secret ─────────────────────────────────────
ADMIN_PREVIEW_SECRET=

# ── PostHog product analytics (Phase B) ────────────────────────────────────
# Create a free PostHog Cloud project at https://eu.posthog.com (EU region
# keeps data GDPR-compliant). Copy the Project API key from
# Settings → Project → API key.
#
# Both vars are PUBLIC by design — PostHog's JS SDK runs in the browser.
# The "host" can stay as "/ingest" so requests proxy through our domain
# (configured in next.config.ts rewrites) and survive ad-blockers.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=/ingest

# ── Supabase (Phase В — auth + profile + cross-tool synergy) ───────────────
# Get these from your Supabase project → Settings → API.
# - URL: e.g. https://abcd1234.supabase.co
# - ANON KEY: a long JWT starting with "eyJ..." — safe to expose, RLS-gated.
# - SERVICE ROLE KEY: never expose; only used by server-side admin scripts
#   (Phase В itself doesn't need it, kept here for forward compat).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Future (Phase Д — Telegram notifications) ──────────────────────────────
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHANNEL_ID=
